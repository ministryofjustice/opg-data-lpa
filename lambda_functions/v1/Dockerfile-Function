FROM public.ecr.aws/lambda/python:3.13@sha256:d06017a94ef7b5d5b342639a7e9efc7b634973460d98a4cb12d321b6aec11797 AS build

WORKDIR /app

COPY lambda_functions/v1/requirements/requirements.txt requirements.txt

RUN pip install --upgrade pip -t python/
RUN pip install -r requirements.txt -t python/

COPY lambda_functions/v1/functions/lpa/ python/

FROM public.ecr.aws/lambda/python:3.13@sha256:d06017a94ef7b5d5b342639a7e9efc7b634973460d98a4cb12d321b6aec11797 AS runtime

WORKDIR /var/task

COPY --from=build /app/python ./

RUN rm -f /usr/local/bin/aws-lambda-rie

CMD [ "app.lpa.lambda_handler" ]
