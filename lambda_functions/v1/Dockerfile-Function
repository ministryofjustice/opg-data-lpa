FROM public.ecr.aws/lambda/python:3.13@sha256:f22a75ddc4ea167a7210b62e4d49aa23f9f1dcd52d1d6084188269a9bf035819 AS build

WORKDIR /app

COPY lambda_functions/v1/requirements/requirements.txt requirements.txt

RUN pip install -r requirements.txt -t python/

COPY lambda_functions/v1/functions/lpa/ python/

FROM public.ecr.aws/lambda/python:3.13@sha256:f22a75ddc4ea167a7210b62e4d49aa23f9f1dcd52d1d6084188269a9bf035819 AS runtime

WORKDIR /var/task

COPY --from=build /app/python ./

RUN rm -f /usr/local/bin/aws-lambda-rie

CMD [ "app.lpa.lambda_handler" ]
